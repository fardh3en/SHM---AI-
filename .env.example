# ─── SHM-AI Platform — Environment Configuration ──────────────────────────────
# Copy this file to .env and adjust values for your environment.
# Never commit .env to source control.

# ── Application ────────────────────────────────────────────────────────────────
APP_NAME=SHM-AI Platform
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true

# ── API ────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501

# ── Database ───────────────────────────────────────────────────────────────────
# Development: SQLite (auto-created)
DATABASE_URL=sqlite+aiosqlite:///./data/shm_ai.db
DATABASE_ECHO=false

# Production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/shm_ai

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Vision Engine (Phase 2) ────────────────────────────────────────────────────
# Model file name — must exist in ./weights/ directory
# Use "yolo11n-seg.pt" as placeholder (auto-downloaded by Ultralytics)
# Replace with your fine-tuned crack detection model when available
DEFAULT_MODEL_NAME=yolo11n-seg.pt

# Inference device: "auto" detects CUDA automatically, falls back to CPU
# Options: "auto" | "cuda" | "cpu"
INFERENCE_DEVICE=auto

# Detection thresholds
CONFIDENCE_THRESHOLD=0.25
IOU_THRESHOLD=0.45

# Sliced inference window (from legacy WhatTheCrack algorithm)
SLICE_HEIGHT=640
SLICE_WIDTH=640
SLICE_OVERLAP_RATIO=0.4
